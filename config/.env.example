# ═══════════════════════════════════════════════════════════
#  Healthcare + Fitness Agent — Environment Variables
#  Copy this file to config/.env and fill in real values
# ═══════════════════════════════════════════════════════════

# ── Azure OpenAI ──────────────────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ── Application ───────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-use-openssl-rand-hex-32
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/health.db

# ── Storage Paths ─────────────────────────────────────────
PDF_STORAGE_PATH=./data/pdfs
FAISS_INDEX_PATH=./data/faiss_index
DRUG_KNOWLEDGE_PATH=./data/drug_knowledge

# ── Embedding ─────────────────────────────────────────────
EMBEDDING_CHUNK_SIZE=500
EMBEDDING_CHUNK_OVERLAP=50
FAISS_TOP_K=5

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── Frontend URL (used in OAuth & Stripe return URLs) ─────
FRONTEND_URL=http://localhost:3000

# ── Google OAuth 2.0 (F1) ─────────────────────────────────
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add Authorised redirect URIs:
#    - http://localhost:8000/auth/callback       (local dev)
#    - http://localhost:3000/api/auth/callback   (Docker)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ── Stripe (F2) ───────────────────────────────────────────
# 1. Get API keys at: https://dashboard.stripe.com/apikeys
# 2. Create a webhook at: https://dashboard.stripe.com/webhooks
#    Events: checkout.session.completed, customer.subscription.deleted,
#            invoice.payment_failed
# 3. Create subscription products/prices in the Stripe dashboard
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STANDARD=price_standard_monthly_id
STRIPE_PRICE_PREMIUM=price_premium_monthly_id
